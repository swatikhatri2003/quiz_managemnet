PORT=4000
NODE_ENV=development

# MAMP: MySQL often runs on port 8889. Set DB_PASSWORD to match
# MAMP → WebStart page → MySQL, or MAMP preferences (default is often "root").
DB_HOST=127.0.0.1
DB_PORT=8889
DB_USER=root
DB_PASSWORD=root
DB_NAME=quiz_management

# Used to build public image URLs in API responses
PUBLIC_BASE_URL=http://localhost:4000
